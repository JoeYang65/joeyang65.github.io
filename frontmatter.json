{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.taxonomy.frontMatterType": "TOML",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "pageBundle": true,
      "allowAsSubContent": true,
      "previewPath": null,
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "summary",
          "name": "summary",
          "type": "string"
        },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true,
          "dateFormat": "yyyy-MM-dd'T'HH:mm:ssXXX"
        },
        {
          "title": "Content preview",
          "name": "featureimage",
          "type": "image"
        },
        {
          "title": "Is in draft",
          "name": "draft",
          "type": "draft"
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "Categories",
          "name": "categories",
          "type": "categories"
        },
        {
          "title": "weight",
          "name": "weight",
          "type": "number"
        },
        {
          "title": "series",
          "name": "series",
          "type": "list"
        },
        {
          "title": "series_order",
          "name": "series_order",
          "type": "number"
        },
        {
          "title": "showHero",
          "name": "showHero",
          "type": "boolean"
        },
        {
          "title": "heroStyle",
          "name": "heroStyle",
          "type": "string"
        }
      ]
    }
  ],
  "frontMatter.framework.id": "hugo",
  "frontMatter.content.publicFolder": "assets",
  "frontMatter.preview.host": "http://localhost:1313",
  "frontMatter.content.pageFolders": [
    {
      "title": "contentPage",
      "path": "[[workspace]]/content",
      "contentTypes": [
        "default"
      ]
    }
  ],
  "frontMatter.git.enabled": true,
  "frontMatter.git.commitMessage": "Synced {{year}}-{{month}}-{{day}}"
}